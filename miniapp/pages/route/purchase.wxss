.order-summary { background: linear-gradient(135deg, #E8F1FB, #1F5FA8); color: #fff; padding: 32rpx; }
.summary-row { margin-bottom: 12rpx; font-size: 28rpx; }
.form-card { padding: 24rpx; }
.form-item { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 26rpx; color: #595959; margin-bottom: 8rpx; }
.form-input { border: 2rpx solid #E5E5E5; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; width: 100%; }
.form-picker { border: 2rpx solid #E5E5E5; border-radius: 12rpx; padding: 16rpx; background: #fff; }
.visitor-title { font-weight: 700; margin-bottom: 12rpx; font-size: 28rpx; }
.submit-btn { margin: 32rpx 0; width: 100%; }
.tips { text-align: center; font-size: 24rpx; color: #8C8C8C; margin: 16rpx 0; }
