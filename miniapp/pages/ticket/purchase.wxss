.eticket-card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.eticket-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.eticket-title { font-size: 32rpx; font-weight: 700; }
.eticket-status { font-size: 28rpx; font-weight: 500; }
.qr-section { text-align: center; padding: 32rpx 0; background: #F7F8FA; border-radius: 16rpx; margin-bottom: 24rpx; }
.qr-canvas { width: 280rpx; height: 280rpx; margin: 0 auto; }
.qr-code-text { font-size: 20rpx; color: #8C8C8C; margin-top: 12rpx; word-break: break-all; }
.eticket-info { padding: 16rpx 0; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.info-label { color: #8C8C8C; font-size: 26rpx; }
.info-value { font-size: 26rpx; font-weight: 500; }
.eticket-tips { background: #FFF7E6; padding: 16rpx; border-radius: 12rpx; font-size: 24rpx; color: #FAAD14; margin-top: 24rpx; }
