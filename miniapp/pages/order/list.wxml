<view class="container">
  <!-- 状态筛选Tab -->
  <scroll-view scroll-x class="tab-scroll">
    <block wx:for="{{statusTabs}}" wx:key="key">
      <view class="tab-item {{status === item.key ? 'active' : ''}}" data-status="{{item.key}}" bindtap="onTabChange">
        {{item.label}}
      </view>
    </block>
  </scroll-view>

  <block wx:for="{{orders}}" wx:key="orderNo">
    <view class="card order-card" bindtap="goDetail" data-no="{{item.orderNo}}">
      <view class="order-header">
        <text class="tag {{item.orderType === 'ticket' ? 'tag-primary' : 'tag-orange'}}">
          {{item.orderType === 'ticket' ? '门票' : '路线'}}
        </text>
        <text class="order-target">{{item.targetName}}</text>
        <text class="order-status">{{statusMap[item.orderStatus]}}</text>
      </view>
      <view class="order-info">
        <text>订单号: {{item.orderNo}}</text>
        <text>日期: {{item.useDate}} | 数量: {{item.quantity}}</text>
        <text class="price">¥{{item.totalAmount}}</text>
      </view>
      <view class="order-actions" wx:if="{{item.orderStatus === 'pending_pay'}}">
        <button class="btn-outline" size="mini" data-no="{{item.orderNo}}" catchtap="cancelOrder">取消</button>
      </view>
    </view>
  </block>

  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <text>暂无订单</text>
  </view>
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
</view>
