.order-detail-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 20rpx; border-bottom: 1rpx solid #E5E5E5; margin-bottom: 20rpx; }
.order-no { font-size: 24rpx; color: #8C8C8C; }
.status-tag { font-size: 26rpx; font-weight: 700; color: #1F5FA8; }
.detail-row { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid #F0F0F0; font-size: 28rpx; }
.section-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.eticket-item { padding: 20rpx; background: #E8F1FB; border-radius: 12rpx; margin-bottom: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.eticket-name { font-weight: 500; }
.eticket-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.eticket-status.unused { background: #1F5FA8; color: #fff; }
.eticket-status.used { background: #52C41A; color: #fff; }
.eticket-status.refunded { background: #FF4D4F; color: #fff; }
.eticket-code { font-size: 20rpx; color: #8C8C8C; }
.action-bar { margin-top: 32rpx; display: flex; gap: 16rpx; }
.action-bar button { flex: 1; }
