<view wx:if="{{!loading}}">
  <view class="hero">
    <view class="hero-bg">Miao Village</view>
    <view class="hero-info">
      <view class="hero-title">{{scenic.name}}</view>
      <view class="hero-meta">Location: {{scenic.address}}</view>
      <view class="hero-meta">Time: {{scenic.openTime}}</view>
    </view>
    <view class="fav-btn" bindtap="toggleFav">
      <text>{{favText}}</text>
    </view>
  </view>

  <view class="container">
    <view class="card section-card">
      <view class="section-title">Introduction</view>
      <view class="section-content">{{scenic.description}}</view>
    </view>

    <view class="card section-card">
      <view class="section-title">Tickets</view>
      <block wx:for="{{tickets}}" wx:key="ticketTypeId">
        <view class="ticket-item">
          <view class="ticket-info">
            <view class="ticket-name">{{item.name}}</view>
            <view class="ticket-note" wx:if="{{item.usageNote}}">{{item.usageNote}}</view>
          </view>
          <view class="ticket-price">
            <text class="price">Y{{item.price}}</text>
            <text class="market-price" wx:if="{{item.marketPrice}}">Y{{item.marketPrice}}</text>
          </view>
          <button class="btn-primary ticket-btn" data-ticket="{{item}}" bindtap="buyTicket">Buy</button>
        </view>
      </block>
      <view wx:if="{{tickets.length === 0}}" style="color:gray;text-align:center;padding:24rpx;">
        No tickets
      </view>
    </view>

    <view class="card section-card">
      <view class="section-title">Reviews ({{reviews.length}})</view>
      <block wx:for="{{reviews}}" wx:key="reviewId">
        <view class="review-item">
          <view class="review-header">
            <text class="review-user">{{item.userName}}</text>
            <text class="review-rating">{{item.ratingText}}</text>
          </view>
          <view class="review-content">{{item.content}}</view>
          <view wx:if="{{item.reply}}" class="review-reply">Reply: {{item.reply}}</view>
        </view>
      </block>
    </view>
  </view>
</view>

<view wx:if="{{loading}}" class="loading">Loading...</view>
