.search-box {
  display: flex; gap: 16rpx; margin-bottom: 24rpx;
}
.search-input {
  flex: 1; height: 72rpx; background: #fff; border-radius: 36rpx;
  padding: 0 32rpx; font-size: 28rpx; border: 2rpx solid var(--border-primary);
}
.search-btn {
  height: 72rpx; line-height: 72rpx; padding: 0 32rpx;
  background: var(--color-primary); color: #fff; border-radius: 36rpx;
  font-size: 28rpx;
}
.scenic-card {
  display: flex; padding: 24rpx;
}
.scenic-cover {
  width: 200rpx; height: 200rpx; border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  display: flex; align-items: center; justify-content: center; margin-right: 24rpx;
}
.scenic-icon { font-size: 64rpx; }
.scenic-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.scenic-name { font-size: 32rpx; font-weight: 700; }
.scenic-addr, .scenic-time { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
.scenic-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.price-desc { font-size: 24rpx; color: var(--text-tertiary); font-weight: 400; }
.loading { text-align: center; padding: 80rpx 0; color: var(--text-tertiary); }
