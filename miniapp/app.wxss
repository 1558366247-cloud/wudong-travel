/* 品牌色变量 */
page {
  --color-primary: #1F5FA8;
  --color-primary-dark: #0E3D75;
  --color-primary-light: #E8F1FB;
  --color-orange: #E85D2F;
  --color-green: #6B8E3D;
  --color-gold: #D4A14B;
  --text-primary: #1A1A1A;
  --text-secondary: #595959;
  --text-tertiary: #8C8C8C;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F7F8FA;
  --border-primary: #E5E5E5;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-light: 0 4rpx 16rpx rgba(0,0,0,0.06);

  background-color: var(--bg-secondary);
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
  overflow: hidden;
  margin-bottom: 24rpx;
}

/* 价格 */
.price {
  color: var(--color-orange);
  font-weight: 700;
  font-size: 36rpx;
}
.price-symbol { font-size: 28rpx; }
.market-price {
  color: var(--text-tertiary);
  text-decoration: line-through;
  font-size: 24rpx;
  margin-left: 12rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}
.tag-primary { background: var(--color-primary-light); color: var(--color-primary); }
.tag-orange { background: #FFF1EA; color: var(--color-orange); }
.tag-green { background: #F6FFED; color: var(--color-green); }

/* 按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-primary:active { background: var(--color-primary-dark); }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-tertiary);
}
.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
}
